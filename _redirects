# Cloudflare Pages / Netlify routing
# Format: source destination [status]
# Status 200 = rewrite (URL stays the same), 301 = permanent redirect, 404 = not found

# ---------- Article routing ----------
# Sanity posts are pre-rendered at build time into /insights/<slug>.html
# (see scripts/generate-insights.js). Cloudflare Pages serves them automatically
# when a request matches the file name (e.g. /insights/foo -> insights/foo.html).
# Slugs without a pre-rendered file fall through to the 404 rule at the bottom.

# ---------- Legacy URL redirects (301) ----------
# Old /article/<slug> URLs -> /insights/<slug>
/article/*  /insights/:splat  301

# Old /blogs and /blog URLs -> /insights
