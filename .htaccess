RewriteEngine On

# 0. Force canonical host: redirect non-www to www (must run first)
RewriteCond %{HTTP_HOST} ^croncore\.com$ [NC]
RewriteRule ^(.*)$ https://www.croncore.com/$1 [R=301,L]

# 1. Redirect /index.html to /
RewriteRule ^index\.html$ / [R=301,L]

# 2. Redirect /page.html to /page (External Redirect)
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [L,R=301]

# 3. Sanity posts are pre-rendered at build time to /insights/<slug>.html
#    (see scripts/generate-insights.js). Serve them when they exist; unmatched
#    slugs fall through to the 404 fallback at the bottom of this file.
RewriteCond %{DOCUMENT_ROOT}/insights/$1.html -f
RewriteRule ^insights/(.+)$ insights/$1.html [L]

# 3b. Redirect old /article/ URLs to /insights/ for SEO
RewriteRule ^article/(.+)$ /insights/$1 [R=301,L]

# 3c. Redirect retired WordPress blog post URLs -> /insights hub
RewriteRule ^insights/custom-ai-chatbot-development$ /insights [R=301,L]
RewriteRule ^insights/unleash-your-business-potential$ /insights [R=301,L]
RewriteRule ^insights/how-ai-agents-are-becoming-your-newes$ /insights [R=301,L]
RewriteRule ^insights/the-predictive-pivot$ /insights [R=301,L]

# 3d. Redirect old contact slug
RewriteRule ^contact-sales$ /contact [R=301,L]

# 4. 301 Redirects for old case study URLs
RewriteRule ^case-study-bezninja$ /case-study-autonomous-sales-agent-drives-record-revenue-growth [R=301,L]
RewriteRule ^case-study-bloomlink$ /case-study-sovereign-voice-engine-for-mongolia [R=301,L]
RewriteRule ^case-study-edtech$ /case-study-architecting-a-ground-up-digital-learning-powerhouse [R=301,L]
RewriteRule ^case-study-oracle$ /case-study-custom-ai-voice-agent-closes-the-speed-to-lead-gap [R=301,L]
RewriteRule ^case-study-knowles$ /case-study-custom-ai-voice-agent-closes-the-speed-to-lead-gap [R=301,L]

# 5. Internally map /page to /page.html (Internal Rewrite)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*?)/?$ $1.html [L]

# 6. 404 fallback: anything that did not match a real file or rule above
ErrorDocument 404 /404.html
